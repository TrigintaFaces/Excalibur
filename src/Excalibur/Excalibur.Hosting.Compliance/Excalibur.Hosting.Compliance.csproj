<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- NuGet Package Metadata -->
    <PackageId>Excalibur.Hosting.Compliance</PackageId>
    <Description>IExcaliburBuilder bridge extensions for the Excalibur compliance (GDPR) subsystem. Provides single-composition-root wiring via AddExcalibur(excalibur =&gt; excalibur.AddGdprErasure(...)).</Description>
    <PackageTags>excalibur;hosting;compliance;gdpr;bridge</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
    <DispatchPackageVersion Condition="'$(DispatchPackageVersion)' == ''">0.0.0-local</DispatchPackageVersion>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.Hosting\Excalibur.Hosting.csproj" />
  </ItemGroup>
  <!-- Development mode: Dispatch.Compliance ProjectReference -->
  <ItemGroup Condition="'$(UsePackageReferences)' != 'true'">
    <ProjectReference Include="..\Excalibur.Compliance\Excalibur.Compliance.csproj" />
  </ItemGroup>
  <!-- CI mode: PackageReference for Dispatch.Compliance -->
  <ItemGroup Condition="'$(UsePackageReferences)' == 'true'">
    <PackageReference Include="Excalibur.Compliance" VersionOverride="$(DispatchPackageVersion)" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
