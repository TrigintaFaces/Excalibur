<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>Excalibur.Data.CosmosDb</PackageId>
    <Description>Azure Cosmos DB data provider implementation for Excalibur cloud-native data access.</Description>
    <PackageTags>excalibur;data;cosmosdb;azure;cloud-native;document-database</PackageTags>
    <!-- AOT: NOT compatible. Microsoft.Azure.Cosmos uses reflection for document serialization. -->
    <IsAotCompatible>false</IsAotCompatible>
    <AzureCosmosDisableNewtonsoftJsonCheck>true</AzureCosmosDisableNewtonsoftJsonCheck>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Excalibur.Data.CosmosDb.Tests" />
    <InternalsVisibleTo Include="Excalibur.Integration.Tests" />
    <!-- Sibling Cosmos packages call the internal AddCosmosDbChangeFeedDurabilityDefaults shared helper
         (change-feed durability default + non-durable startup warning) so an ES-only / Outbox-only
         consumer is never silently non-durable (bd-ydln24). Kept internal — consumers opt into durability
         via the public AddCosmosDbChangeFeedCheckpointStore, never this. -->
    <InternalsVisibleTo Include="Excalibur.EventSourcing.CosmosDb" />
    <InternalsVisibleTo Include="Excalibur.Outbox.CosmosDb" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Azure.Cosmos" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.A3.Abstractions\Excalibur.A3.Abstractions.csproj" />
    <ProjectReference Include="..\Excalibur.Cdc\Excalibur.Cdc.csproj" />
    <ProjectReference Include="..\Excalibur.Data.Abstractions\Excalibur.Data.Abstractions.csproj" />
    <ProjectReference Include="..\Excalibur.EventSourcing\Excalibur.EventSourcing.csproj" />
    <ProjectReference Include="..\Excalibur.Saga\Excalibur.Saga.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>