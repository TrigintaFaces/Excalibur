<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>Excalibur.Outbox.MongoDB</PackageId>
    <Description>MongoDB bridge package for the Excalibur outbox pattern. Provides IOutboxBuilder.UseMongoDB() integration.</Description>
    <PackageTags>excalibur;outbox;mongodb;cloud-native;event-sourcing;messaging</PackageTags>
    <IsAotCompatible>false</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.Data.MongoDB\Excalibur.Data.MongoDB.csproj" />
    <ProjectReference Include="..\Excalibur.Outbox\Excalibur.Outbox.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>
</Project>
