<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- NuGet Package Metadata -->
    <PackageId>Excalibur.A3.Policy.Cedar</PackageId>
    <Description>Cedar policy engine HTTP adapter for Excalibur A3 authorization. Implements IAuthorizationEvaluator via REST/HTTP calls to a Cedar agent or Amazon Verified Permissions.</Description>
    <PackageTags>excalibur;authorization;cedar;policy;aws;verified-permissions</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Excalibur.A3.Policy.Cedar.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.A3.Abstractions\Excalibur.A3.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" />
  </ItemGroup>
</Project>
