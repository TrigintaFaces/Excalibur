<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- NuGet Package Metadata -->
    <PackageId>Excalibur.A3.Policy.Opa</PackageId>
    <Description>Open Policy Agent (OPA) HTTP adapter for Excalibur A3 authorization. Implements IAuthorizationEvaluator via REST/HTTP calls to an OPA server.</Description>
    <PackageTags>excalibur;authorization;opa;policy;open-policy-agent</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Excalibur.A3.Policy.Opa.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.A3.Abstractions\Excalibur.A3.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>
</Project>
