<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- NuGet package metadata -->
    <PackageId>Excalibur.Saga</PackageId>
    <Description>Saga pattern abstractions for Excalibur, providing persistence interfaces for long-running business processes and distributed workflows.</Description>
    <PackageTags>excalibur;saga;process-manager;workflow;distributed-transactions</PackageTags>
    <!-- AOT: Compatible. SagaCoordinator uses RuntimeFeature.IsDynamicCodeSupported dual-path:
         AOT path uses ISagaDispatchRegistry/ISagaTypeRegistry/ISagaContextFactory (source-gen safe).
         JIT path uses MakeGenericMethod (reflection). Both paths are properly annotated. -->
    <IsAotCompatible>true</IsAotCompatible>
    <DispatchPackageVersion Condition="'$(DispatchPackageVersion)' == ''">0.0.0-local</DispatchPackageVersion>
  </PropertyGroup>
  <!-- AOT Configuration -->
  <PropertyGroup>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <PublishAot Condition="'$(PublishAot)' == ''">false</PublishAot>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Update="Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <Compile Update="Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>
  <PropertyGroup>
    <SuppressTrimAnalysisWarnings>false</SuppressTrimAnalysisWarnings>
    <TrimmerDefaultAction>link</TrimmerDefaultAction>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.Data.Abstractions\Excalibur.Data.Abstractions.csproj" />
    <ProjectReference Include="..\Excalibur.Hosting\Excalibur.Hosting.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReferences)' != 'true'">
    <ProjectReference Include="..\..\Dispatch\Excalibur.Dispatch.Abstractions\Excalibur.Dispatch.Abstractions.csproj" />
    <ProjectReference Include="..\..\Dispatch\Excalibur.Dispatch\Excalibur.Dispatch.csproj" />
  </ItemGroup>
  <!-- CI mode: PackageReference for Dispatch packages -->
  <ItemGroup Condition="'$(UsePackageReferences)' == 'true'">
    <PackageReference Include="Excalibur.Dispatch.Abstractions" VersionOverride="$(DispatchPackageVersion)" />
    <PackageReference Include="Excalibur.Dispatch" VersionOverride="$(DispatchPackageVersion)" />
  </ItemGroup>
  <!-- Enable testing of internal types -->
  <ItemGroup>
    <InternalsVisibleTo Include="Excalibur.Saga.Tests" />
    <InternalsVisibleTo Include="Excalibur.Dispatch.Patterns.Tests" />
    <InternalsVisibleTo Include="Excalibur.Testing.Conformance.Tests" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
    <!-- S795 A2: IVT granted to test assemblies that retain direct access to the
         AddExcaliburSaga aggregator per COMPASS msg 1498 §1 — migration to
         IExcaliburBuilder.AddSagas() would force >2 file / >1h rewrite of
         existing test fixtures that predate the S792 bridge. -->
    <InternalsVisibleTo Include="Excalibur.Dispatch.Integration.Tests" />
    <InternalsVisibleTo Include="Excalibur.Dispatch.Tests.Smoke" />
    <InternalsVisibleTo Include="Excalibur.Data.DynamoDb.Tests" />
    <InternalsVisibleTo Include="Excalibur.Data.Postgres.Tests" />
    <InternalsVisibleTo Include="Excalibur.Data.Tests" />
    <InternalsVisibleTo Include="Excalibur.Hosting.Tests" />
    <InternalsVisibleTo Include="Excalibur.Tests" />
  </ItemGroup>
</Project>
