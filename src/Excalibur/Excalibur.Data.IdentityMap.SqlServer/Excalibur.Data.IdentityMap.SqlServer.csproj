<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>Excalibur.Data.IdentityMap.SqlServer</PackageId>
    <Description>SQL Server identity map store implementation for Excalibur, providing durable external-to-internal aggregate ID resolution.</Description>
    <PackageTags>excalibur;identity-map;sqlserver;cdc;anti-corruption</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Excalibur.Data.IdentityMap.Tests" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" PublicKey="" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.Data.IdentityMap\Excalibur.Data.IdentityMap.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Microsoft.Data.SqlClient" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
