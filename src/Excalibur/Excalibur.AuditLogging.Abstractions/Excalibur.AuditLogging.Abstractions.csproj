<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RootNamespace>Excalibur.AuditLogging</RootNamespace>
    <PackageId>Excalibur.AuditLogging.Abstractions</PackageId>
    <Description>Audit-trail integrity abstractions for the Excalibur framework. Defines the shared, backend-agnostic tamper-evidence contract (keyed-MAC + hash-chain) consumed by every audit sink, plus the deterministic record canonicalization helper and the signing-key provider abstraction.</Description>
    <PackageTags>audit;integrity;tamper-evidence;hmac;hash-chain;security;abstractions</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
