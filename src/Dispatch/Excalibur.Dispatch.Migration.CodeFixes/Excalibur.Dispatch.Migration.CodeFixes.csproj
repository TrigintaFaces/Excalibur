<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- Analyzers/code-fixes MUST target netstandard2.0 only -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <TargetFrameworks></TargetFrameworks>
    <!-- CPM opt-out: pin Roslyn SDK to the minimum compiler version supported (must not float). -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <EnableDefaultAnalyzers>false</EnableDefaultAnalyzers>
    <IsRoslynComponent>true</IsRoslynComponent>
    <IncludeBuildOutput>true</IncludeBuildOutput>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>false</IncludeSymbols>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <NoWarn>$(NoWarn);NU5017;NU5128;RS2008</NoWarn>
    <LangVersion>12.0</LangVersion>
    <IsAotCompatible>false</IsAotCompatible>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>
    <IsTrimmable>false</IsTrimmable>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <Description>Roslyn code-fix providers for migrating off the now-commercial MediatR/MassTransit packages onto Excalibur.Dispatch. Provides automatic rewrites for the EXMIG diagnostics emitted by Excalibur.Dispatch.Migration.Analyzers.</Description>
    <PackageTags>dispatch;migration;mediatr;masstransit;codefix;roslyn;codemod</PackageTags>
  </PropertyGroup>
  <!-- Test accessibility -->
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Excalibur.Dispatch.Migration.CodeFixes.Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Excalibur.Dispatch.SourceGenerators.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Remove="Microsoft.SourceLink.GitHub" />
    <PackageReference Remove="Microsoft.CodeAnalysis.Analyzers" />
    <PackageReference Remove="Microsoft.CodeAnalysis.NetAnalyzers" />
    <PackageReference Remove="Microsoft.CodeAnalysis.PublicApiAnalyzers" />
    <PackageReference Remove="Microsoft.CodeAnalysis.BannedApiAnalyzers" />
    <PackageReference Remove="StyleCop.Analyzers" />
    <PackageReference Remove="Meziantou.Analyzer" />
    <PackageReference Remove="Roslynator.Analyzers" />
  </ItemGroup>
  <ItemGroup>
    <!-- Roslyn 4.14.0 = VS 17.14 / .NET SDK 9.0.300+. Workspaces required for code-fix providers. -->
    <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="4.14.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.14.0" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <!-- Shares the EXMIG diagnostic ID constants (FixableDiagnosticIds); compile-time only, not packed. -->
    <ProjectReference Include="..\Excalibur.Dispatch.Migration.Analyzers\Excalibur.Dispatch.Migration.Analyzers.csproj" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
