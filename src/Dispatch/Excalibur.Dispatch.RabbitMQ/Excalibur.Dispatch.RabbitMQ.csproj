<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>Excalibur.Dispatch.RabbitMQ</PackageId>
    <Description>Experience metapackage bundling Excalibur.Dispatch with RabbitMQ transport. Provides a single AddDispatchRabbitMQ() call for the common RabbitMQ messaging scenario.</Description>
    <PackageTags>excalibur;dispatch;rabbitmq;messaging;metapackage</PackageTags>
  </PropertyGroup>
  <PropertyGroup>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.Dispatch\Excalibur.Dispatch.csproj" />
    <ProjectReference Include="..\Excalibur.Dispatch.Transport.RabbitMQ\Excalibur.Dispatch.Transport.RabbitMQ.csproj" />
    <ProjectReference Include="..\Excalibur.Dispatch.Resilience.Polly\Excalibur.Dispatch.Resilience.Polly.csproj" />
    <ProjectReference Include="..\Excalibur.Dispatch.Observability\Excalibur.Dispatch.Observability.csproj" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>
</Project>
