<Project>

  <PropertyGroup>
    <DispatchSourceGeneratorsPath Condition="'$(DispatchSourceGeneratorsPath)' == ''">$(MSBuildThisFileDirectory)..\</DispatchSourceGeneratorsPath>

    <!-- PERF-9: Enable C# 12 interceptors for compile-time dispatch optimization -->
    <!-- Interceptors require explicit namespace opt-in; net10.0 supports them unconditionally -->
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Excalibur.Dispatch.Generated</InterceptorsNamespaces>
  </PropertyGroup>

</Project>