<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>Excalibur.Dispatch.Validation.FluentValidation</PackageId>
    <Description>FluentValidation integration for the Excalibur framework. Provides IValidatorResolver implementation using FluentValidation validators.</Description>
    <PackageTags>dispatch;validation;fluentvalidation;cqrs;messaging</PackageTags>
    <!-- AOT: Compatible via dual-path pattern. FluentValidatorResolver (JIT) annotated with [RequiresDynamicCode]; AotFluentValidatorResolver (AOT) uses source-generated dispatch. -->
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.Dispatch\Excalibur.Dispatch.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Excalibur.Dispatch.Middleware.Tests" />
  </ItemGroup>
</Project>