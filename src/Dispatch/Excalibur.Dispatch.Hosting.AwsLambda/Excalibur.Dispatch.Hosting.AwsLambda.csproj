<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IsAotCompatible>true</IsAotCompatible>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <DefineConstants>$(DefineConstants);AWS_LAMBDA_SUPPORT</DefineConstants>
    <RootNamespace>Excalibur.Dispatch.Hosting.AwsLambda</RootNamespace>
    <AssemblyName>Excalibur.Dispatch.Hosting.AwsLambda</AssemblyName>
    <PackageId>$(AssemblyName)</PackageId>
    <Description>AWS Lambda hosting integration for the Excalibur framework.</Description>
    <PackageTags>dispatch;serverless;hosting;aws;lambda;messaging</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Excalibur.Dispatch.Abstractions\Excalibur.Dispatch.Abstractions.csproj" />
    <ProjectReference Include="..\Excalibur.Dispatch.Hosting.Serverless.Abstractions\Excalibur.Dispatch.Hosting.Serverless.Abstractions.csproj" />
    <ProjectReference Include="..\Excalibur.Dispatch\Excalibur.Dispatch.csproj" />
  </ItemGroup>
  <!-- AWS Lambda Dependencies -->
  <ItemGroup>
    <PackageReference Include="Amazon.Lambda.RuntimeSupport" />
    <PackageReference Include="Amazon.Lambda.Serialization.SystemTextJson" />
    <PackageReference Include="Amazon.Lambda.APIGatewayEvents" />
    <PackageReference Include="Amazon.Lambda.SQSEvents" />
    <PackageReference Include="Amazon.Lambda.SNSEvents" />
    <PackageReference Include="Amazon.Lambda.DynamoDBEvents" />
    <PackageReference Include="Amazon.Lambda.KinesisEvents" Condition="'$(AllowAwsSdkV4)' == 'true'" />
    <PackageReference Include="AWSSDK.Extensions.NETCore.Setup" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Excalibur.Dispatch.Hosting.Serverless.Tests" />
    <InternalsVisibleTo Include="Excalibur.Dispatch.Hosting.Tests" />
    <InternalsVisibleTo Include="Excalibur.Hosting.Tests" />
    <InternalsVisibleTo Include="Excalibur.Dispatch.Tests.Functional" />
    <InternalsVisibleTo Include="Excalibur.Dispatch.Tests.Smoke" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>
</Project>
