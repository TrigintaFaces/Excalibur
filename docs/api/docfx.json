{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Dispatch/**/*.csproj"
          ],
          "src": "../../"
        }
      ],
      "dest": "api-dispatch",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "enumSortOrder": "alphabetic",
      "filter": "filterConfig.yml"
    },
    {
      "src": [
        {
          "files": [
            "src/Excalibur/**/*.csproj"
          ],
          "src": "../../"
        }
      ],
      "dest": "api-excalibur",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "enumSortOrder": "alphabetic",
      "filter": "filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api-dispatch/**.yml",
          "api-dispatch/index.md"
        ]
      },
      {
        "files": [
          "api-excalibur/**.yml",
          "api-excalibur/index.md"
        ]
      },
      {
        "files": [
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "apidoc/**.md"
        ],
        "exclude": [
          "obj/**",
          "_site/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false,
    "globalMetadata": {
      "_appTitle": "Excalibur.Dispatch API Reference",
      "_appName": "Excalibur.Dispatch",
      "_appFooter": "Excalibur.Dispatch Framework - API Reference Documentation",
      "_enableSearch": true,
      "_enableNewTab": true
    }
  }
}
