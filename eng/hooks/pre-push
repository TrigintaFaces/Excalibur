#!/bin/bash
# pre-push hook: enforce CHANGELOG [Unreleased] update when pushing significant changes.
#
# Triggered when commits touching shipping code, public-API baselines, dep versions,
# or build config are being pushed without a corresponding CHANGELOG.md update.
# Prevents the multi-sprint drift that accumulated pre-S811.
#
# git passes push refs on stdin: "<local_ref> <local_sha> <remote_ref> <remote_sha>\n..."
# For new branches (no remote), remote_sha is all zeros.
#
# Bypass:
#   - export SKIP_CHANGELOG_CHECK=1  (single-push escape hatch)
#   - add "[skip changelog]" anywhere in a commit message in the push range
#   - push --no-verify (skips all hooks)

set -u

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
GRAY='\033[0;37m'
NC='\033[0m'

# Bypass via env var
if [ "${SKIP_CHANGELOG_CHECK:-0}" = "1" ]; then
    echo -e "${YELLOW}pre-push: SKIP_CHANGELOG_CHECK=1 set — skipping CHANGELOG enforcement${NC}"
    exit 0
fi

ZERO="0000000000000000000000000000000000000000"

# Regexes — bash grep -E compatible
# Significant paths: changing these requires a CHANGELOG entry
SIG_RE='^(src/|eng/ci/|\.github/workflows/|Directory\.Packages\.props|Directory\.Build\.(props|targets)|templates/|\.editorconfig|RELEASE\.md|CONTRIBUTING\.md|management/architecture/adr-)'
# Paths excluded from significance (point-in-time / template-config / governance artifacts)
EXCL_RE='(/sprints/|management/governance/framework-governance\.json|/reports/|/\.template\.config/|PublicAPI\.Shipped\.txt$|PublicAPI\.Unshipped\.txt$)'

violation=0

while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip deletions
    if [ "$local_sha" = "$ZERO" ]; then
        continue
    fi

    # Determine the range of commits being pushed
    if [ "$remote_sha" = "$ZERO" ]; then
        # New branch — compare against upstream main as baseline
        if ! base=$(git merge-base "$local_sha" "origin/main" 2>/dev/null); then
            # No origin/main yet — skip check (first-ever push)
            continue
        fi
        range="$base..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    # Commit messages in range — honor "[skip changelog]" marker
    if git log "$range" --format=%B 2>/dev/null | grep -qiE '\[skip[- ]changelog\]'; then
        echo -e "${YELLOW}pre-push: '[skip changelog]' marker found in commit message — skipping${NC}"
        continue
    fi

    # Files changed in this push range
    changed=$(git diff --name-only "$range" 2>/dev/null || echo "")
    [ -z "$changed" ] && continue

    # Significant files
    significant=$(echo "$changed" | grep -E "$SIG_RE" | grep -vE "$EXCL_RE" || true)
    [ -z "$significant" ] && continue

    # Did CHANGELOG.md change in this range?
    if ! echo "$changed" | grep -qx 'CHANGELOG.md'; then
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}pre-push: CHANGELOG.md not updated${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        echo -e "${YELLOW}These commits touch shipping code / deps / build config${NC}"
        echo -e "${YELLOW}but CHANGELOG.md was not modified:${NC}"
        echo ""
        echo "$significant" | head -20 | sed 's/^/  /'
        [ "$(echo "$significant" | wc -l)" -gt 20 ] && echo "  ..."
        echo ""
        echo -e "${CYAN}Add an entry under '## [Unreleased]' (Added / Changed / Fixed / Removed)${NC}"
        echo -e "${CYAN}in CHANGELOG.md, then amend or create a follow-up commit.${NC}"
        echo ""
        echo -e "${GRAY}Bypass options (use sparingly):${NC}"
        echo -e "${GRAY}  SKIP_CHANGELOG_CHECK=1 git push ...${NC}"
        echo -e "${GRAY}  Add '[skip changelog]' to a commit message${NC}"
        echo -e "${GRAY}  git push --no-verify${NC}"
        violation=1
        continue
    fi

    # CHANGELOG changed — verify the [Unreleased] section specifically moved
    base_ref="${remote_sha}"
    [ "$base_ref" = "$ZERO" ] && base_ref=$(git merge-base "$local_sha" "origin/main" 2>/dev/null || echo "")

    if [ -n "$base_ref" ]; then
        # awk extractor: lines between "## [Unreleased]" and the next "## [" header
        base_unrel=$(git show "${base_ref}:CHANGELOG.md" 2>/dev/null | awk '/^## \[Unreleased\]/{f=1;next} /^## \[/&&f{exit} f{print}' || echo "")
        head_unrel=$(git show "${local_sha}:CHANGELOG.md" 2>/dev/null | awk '/^## \[Unreleased\]/{f=1;next} /^## \[/&&f{exit} f{print}' || echo "")

        if [ "$base_unrel" = "$head_unrel" ]; then
            echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo -e "${RED}pre-push: CHANGELOG.md [Unreleased] section not updated${NC}"
            echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo ""
            echo -e "${YELLOW}CHANGELOG.md was modified but not the '## [Unreleased]' block.${NC}"
            echo -e "${YELLOW}New entries for ongoing work must go under [Unreleased]${NC}"
            echo -e "${YELLOW}(moved to a version section only at release cut time).${NC}"
            echo ""
            echo -e "${GRAY}Bypass: SKIP_CHANGELOG_CHECK=1 / '[skip changelog]' / --no-verify${NC}"
            violation=1
        fi
    fi
done

if [ "$violation" -ne 0 ]; then
    echo ""
    exit 1
fi

exit 0
