<?xml version="1.0" encoding="utf-8"?>
<!-- AWS Secrets Manager Security Sample -->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AwsSecretsManagerSample</RootNamespace>
    <AssemblyName>AwsSecretsManagerSample</AssemblyName>
  </PropertyGroup>
  <!-- Dispatch Security References -->
  <ItemGroup>
    <ProjectReference Include="$(DispatchSourceRoot)Excalibur.Dispatch\Excalibur.Dispatch.csproj" />
    <ProjectReference Include="$(DispatchSourceRoot)Excalibur.Dispatch.Abstractions\Excalibur.Dispatch.Abstractions.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Security\Excalibur.Security.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Security.Aws\Excalibur.Security.Aws.csproj" />
  </ItemGroup>
  <!-- AWS SDK References -->
  <ItemGroup>
    <PackageReference Include="AWSSDK.SecretsManager" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
  </ItemGroup>
</Project>