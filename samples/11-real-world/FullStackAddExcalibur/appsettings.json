{
  "ConnectionStrings": {
    "CdcSource":       "Server=localhost,1433;Database=LegacyDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True",
    "EventStore":      "Server=localhost,1434;Database=EventStore;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True",
    "IdentityMap":     "Server=localhost,1434;Database=EventStore;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True",
    "DataProcessing":  "Server=localhost,1434;Database=EventStore;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True"
  },

  "//_EventSourcing_Note": "Bound via BindConfiguration in the Excalibur.EventSourcing.SqlServer builder",
  "EventSourcing": {
    "Sql": {
      "Schema": "dbo",
      "EventsTableName":   "EventStoreEvents",
      "SnapshotTable":     "EventStoreSnapshots",
      "CommandTimeout":    "00:00:30"
    },
    "Snapshots": {
      "EventInterval": 100
    }
  },

  "//_Outbox_Note": "Bound via BindConfiguration in Excalibur.Outbox / Excalibur.Outbox.SqlServer",
  "Outbox": {
    "PollingInterval": "00:00:02",
    "BatchSize": 100,
    "MaxRetries": 5,
    "RetryInitialDelay": "00:00:01",
    "RetryMaxDelay": "00:00:30",
    "Sql": {
      "Schema": "dbo",
      "OutboxTable": "OutboxMessages"
    }
  },

  "//_Cdc_Note": "Bound via BindConfiguration in Excalibur.Cdc.SqlServer",
  "Cdc": {
    "PollingInterval": "00:00:05",
    "BatchSize": 100,
    "StartImmediately": true,
    "InitialDelay": "00:00:02",
    "Sql": {
      "DatabaseName": "LegacyDb",
      "CaptureInstances": [ "dbo_LegacyOrders" ],
      "StopOnMissingTableHandler": false
    }
  },

  "//_IdentityMap_Note": "Bound via BindConfiguration in Excalibur.Data.IdentityMap.SqlServer",
  "IdentityMap": {
    "Sql": {
      "Schema": "dbo",
      "TableName": "IdentityMap"
    }
  },

  "//_Elasticsearch_Note": "Shared options + per-projection overrides",
  "Elasticsearch": {
    "NodeUris": [ "http://localhost:9200" ],
    "ConnectionPoolType": "Sniffing",
    "RequestTimeoutSeconds": 30,
    "ApiKey": "",
    "Projections": {
      "OrderReadModel": {
        "IndexPrefix": "orders",
        "NumberOfShards": 2,
        "NumberOfReplicas": 1
      }
    }
  },

  "//_DataProcessing_Note": "Producer/consumer pipeline (queue + batching)",
  "DataProcessing": {
    "QueueSize": 128,
    "ProducerBatchSize": 50,
    "ConsumerBatchSize": 20,
    "MaxConcurrency": 4
  },

  "//_DataProcessingService_Note": "Background hosted-service options",
  "DataProcessingService": {
    "PollingInterval": "00:00:10",
    "DrainTimeoutSeconds": 60,
    "UnhealthyThreshold": 5
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Excalibur": "Information",
      "FullStackAddExcalibur": "Debug"
    }
  },

  "AllowedHosts": "*"
}
