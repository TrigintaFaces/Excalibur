<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>FullStackAddExcalibur</RootNamespace>
    <!-- Sample code intentionally couples many types and uses demo strings -->
    <NoWarn>$(NoWarn);CA1506;CA1303;CA1505;CA1861;CA2213;MSB3277</NoWarn>
  </PropertyGroup>
  <!-- Dispatch core -->
  <ItemGroup>
    <ProjectReference Include="$(DispatchSourceRoot)Excalibur.Dispatch\Excalibur.Dispatch.csproj" />
    <ProjectReference Include="$(DispatchSourceRoot)Excalibur.Dispatch.Abstractions\Excalibur.Dispatch.Abstractions.csproj" />
  </ItemGroup>
  <!-- Excalibur hosting (AddExcalibur root builder) -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Hosting\Excalibur.Hosting.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Domain\Excalibur.Domain.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Application\Excalibur.Application.csproj" />
  </ItemGroup>
  <!-- Audit: AuditMiddleware + ActivityAudited event + publisher contracts -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.A3\Excalibur.A3.csproj" />
  </ItemGroup>
  <!-- Event Sourcing + SQL Server provider -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.EventSourcing\Excalibur.EventSourcing.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.EventSourcing.SqlServer\Excalibur.EventSourcing.SqlServer.csproj" />
  </ItemGroup>
  <!-- CDC (Change Data Capture) from SQL Server -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Data.SqlServer\Excalibur.Data.SqlServer.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Cdc.SqlServer\Excalibur.Cdc.SqlServer.csproj" />
  </ItemGroup>
  <!-- Outbox for transactional event publishing -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Outbox\Excalibur.Outbox.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Outbox.SqlServer\Excalibur.Outbox.SqlServer.csproj" />
  </ItemGroup>
  <!-- ElasticSearch projections -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Data.ElasticSearch\Excalibur.Data.ElasticSearch.csproj" />
  </ItemGroup>
  <!-- IdentityMap -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Data.IdentityMap\Excalibur.Data.IdentityMap.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Data.IdentityMap.SqlServer\Excalibur.Data.IdentityMap.SqlServer.csproj" />
  </ItemGroup>
  <!-- DataProcessing -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Data.DataProcessing\Excalibur.Data.DataProcessing.csproj" />
  </ItemGroup>
  <!-- Runtime adapters -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
  </ItemGroup>
  <!-- Content files -->
  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="appsettings.Development.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
