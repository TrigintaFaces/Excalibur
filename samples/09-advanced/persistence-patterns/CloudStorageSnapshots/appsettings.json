{
  "ConnectionStrings": {
    "EventStore": "Server=localhost,1434;Database=EventStore;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True",
    "AzureBlob":  "UseDevelopmentStorage=true"
  },

  "//_TieredStorage": "Events older than MaxAge or past MaxPosition roll to the cold store",
  "TieredStorage": {
    "MaxAge": "90.00:00:00",
    "MaxPosition": 10000000,
    "RetainRecentCount": 1000
  },

  "//_AwsS3": "Set these via environment variables in production.",
  "AwsS3": {
    "BucketName": "excalibur-cold-events",
    "KeyPrefix": "events/",
    "Region": "us-east-1"
  },

  "//_AzureBlob": "Leave ConnectionString above for Azurite / use connection string for real accounts.",
  "AzureBlob": {
    "ContainerName": "cold-events",
    "CreateContainerIfNotExists": true
  },

  "//_Gcs": "CredentialsPath: path to a service-account JSON file.",
  "Gcs": {
    "ProjectId": "my-gcp-project",
    "BucketName": "excalibur-cold-events",
    "ObjectPrefix": "events/",
    "CredentialsPath": ""
  },

  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*"
}
