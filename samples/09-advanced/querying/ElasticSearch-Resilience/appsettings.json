{
  "ElasticSearch": {
    "Url": "http://localhost:9200",
    "Resilience": {
      "MaxRetryAttempts": 3,
      "CircuitBreaker": {
        "FailureThreshold": 5,
        "ResetTimeoutSeconds": 30
      }
    },
    "Monitoring": {
      "Tracing": { "ActivitySourceName": "ElasticSearch.Sample" },
      "RequestLogging": { "LogLevel": "Debug", "IncludeRequestBody": true },
      "HealthMonitoring": { "PollIntervalSeconds": 30 }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "ElasticSearch_Resilience": "Information"
    }
  }
}
