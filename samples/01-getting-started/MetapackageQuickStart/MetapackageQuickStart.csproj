<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>MetapackageQuickStart</RootNamespace>
    <NoWarn>$(NoWarn);CA1506;CA1303;CA1861;CA2213;MSB3277</NoWarn>
  </PropertyGroup>

  <!-- Metapackage: one project reference pulls in the full SqlServer stack -->
  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)src\metapackages\Excalibur.SqlServer\Excalibur.SqlServer.csproj" />
  </ItemGroup>

  <!-- Granular: we also reference a couple of individual packages so we can
       demonstrate the composed-by-hand wiring in the same binary. -->
  <ItemGroup>
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.EventSourcing\Excalibur.EventSourcing.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.EventSourcing.SqlServer\Excalibur.EventSourcing.SqlServer.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Outbox\Excalibur.Outbox.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Outbox.SqlServer\Excalibur.Outbox.SqlServer.csproj" />
    <ProjectReference Include="$(ExcaliburSourceRoot)Excalibur.Hosting\Excalibur.Hosting.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
