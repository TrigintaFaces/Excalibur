{
  "$schema": "http://json.schemastore.org/template",
  "author": "Excalibur Contributors",
  "classifications": ["Outbox", "Reliable Messaging", "Excalibur", "Dispatch"],
  "identity": "Excalibur.Dispatch.Outbox",
  "name": "Excalibur Outbox with Dispatch",
  "shortName": "excalibur-outbox",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "Company.ExcaliburOutbox",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        { "choice": "net8.0", "description": "Target .NET 8.0" },
        { "choice": "net9.0", "description": "Target .NET 9.0" },
        { "choice": "net10.0", "description": "Target .NET 10.0" }
      ],
      "defaultValue": "net10.0",
      "replaces": "net8.0"
    },
    "Transport": {
      "type": "parameter",
      "description": "The message transport to use.",
      "datatype": "choice",
      "choices": [
        { "choice": "inmemory", "description": "In-memory transport (default)" },
        { "choice": "kafka", "description": "Apache Kafka" },
        { "choice": "rabbitmq", "description": "RabbitMQ" },
        { "choice": "azureservicebus", "description": "Azure Service Bus" },
        { "choice": "awssqs", "description": "Amazon SQS" },
        { "choice": "googlepubsub", "description": "Google Cloud Pub/Sub" }
      ],
      "defaultValue": "inmemory"
    },
    "Database": {
      "type": "parameter",
      "description": "The database provider for the outbox store.",
      "datatype": "choice",
      "choices": [
        { "choice": "sqlserver", "description": "SQL Server" },
        { "choice": "postgresql", "description": "PostgreSQL" },
        { "choice": "inmemory", "description": "In-memory (development only)" }
      ],
      "defaultValue": "sqlserver"
    },
    "UseKafka": {
      "type": "computed",
      "value": "(Transport == \"kafka\")"
    },
    "UseRabbitMQ": {
      "type": "computed",
      "value": "(Transport == \"rabbitmq\")"
    },
    "UseAzureServiceBus": {
      "type": "computed",
      "value": "(Transport == \"azureservicebus\")"
    },
    "UseAwsSqs": {
      "type": "computed",
      "value": "(Transport == \"awssqs\")"
    },
    "UseGooglePubSub": {
      "type": "computed",
      "value": "(Transport == \"googlepubsub\")"
    },
    "UseSqlServer": {
      "type": "computed",
      "value": "(Database == \"sqlserver\")"
    },
    "UsePostgreSql": {
      "type": "computed",
      "value": "(Database == \"postgresql\")"
    },
    "UseInMemoryDatabase": {
      "type": "computed",
      "value": "(Database == \"inmemory\")"
    },
    "FrameworkVersion": {
      "type": "generated",
      "generator": "switch",
      "replaces": "8.0",
      "parameters": {
        "evaluator": "C++",
        "datatype": "string",
        "cases": [
          { "condition": "(Framework == 'net10.0')", "value": "10.0" },
          { "condition": "(Framework == 'net9.0')", "value": "9.0" },
          { "condition": "", "value": "8.0" }
        ]
      }
    },
  }
}
}
