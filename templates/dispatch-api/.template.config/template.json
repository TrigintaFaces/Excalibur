{
  "$schema": "http://json.schemastore.org/template",
  "author": "Excalibur Contributors",
  "classifications": [
    "Web",
    "API",
    "Dispatch"
  ],
  "identity": "Excalibur.Dispatch.Api",
  "name": "Excalibur Dispatch API",
  "shortName": "dispatch-api",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "Company.DispatchApi",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net10.0",
          "description": "Target .NET 10.0"
        }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    },
    "Transport": {
      "type": "parameter",
      "description": "The message transport to use.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "inmemory",
          "description": "In-memory transport (default)"
        },
        {
          "choice": "kafka",
          "description": "Apache Kafka"
        },
        {
          "choice": "rabbitmq",
          "description": "RabbitMQ"
        },
        {
          "choice": "azureservicebus",
          "description": "Azure Service Bus"
        },
        {
          "choice": "awssqs",
          "description": "Amazon SQS"
        },
        {
          "choice": "googlepubsub",
          "description": "Google Cloud Pub/Sub"
        }
      ],
      "defaultValue": "inmemory"
    },
    "UseKafka": {
      "type": "computed",
      "value": "(Transport == \"kafka\")"
    },
    "UseRabbitMQ": {
      "type": "computed",
      "value": "(Transport == \"rabbitmq\")"
    },
    "UseAzureServiceBus": {
      "type": "computed",
      "value": "(Transport == \"azureservicebus\")"
    },
    "UseAwsSqs": {
      "type": "computed",
      "value": "(Transport == \"awssqs\")"
    },
    "UseGooglePubSub": {
      "type": "computed",
      "value": "(Transport == \"googlepubsub\")"
    },
    "IncludeDocker": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include Dockerfile and .dockerignore.",
      "defaultValue": "false"
    },
    "IncludeTests": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include a test project.",
      "defaultValue": "false"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(!IncludeDocker)",
          "exclude": [
            "Dockerfile",
            ".dockerignore"
          ]
        },
        {
          "condition": "(!IncludeTests)",
          "exclude": [
            "Company.DispatchApi.Tests/**"
          ]
        }
      ]
    }
  ]
}